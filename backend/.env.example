# PostgreSQL (Docker Compose do Gemini)
DATABASE_URL=postgresql://omnimail:SUA_SENHA_AQUI@localhost:5432/omnimail_dev

# JWT - Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_AQUI

# AES-256-GCM - DEVE ter 64 caracteres hex (32 bytes)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=GERE_UMA_CHAVE_ALEATORIA_AQUI_64_HEX

# Remetentes monitorados (separados por vírgula)
MONITORED_SENDERS=contabiletica@hotmail.com

# Frontend URL para CORS
FRONTEND_URL=http://localhost:5173

# Telegram Bot (opcional - crie via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
